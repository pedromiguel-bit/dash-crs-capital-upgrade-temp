# Variáveis de ambiente do dashboard Capital Upgrade.
# No Easypanel, defina estas variáveis no painel do serviço (não comite o .env real).

# Chave da API da Ploomes (header User-Key). OBRIGATÓRIA.
ploomes-api=COLE_AQUI_A_CHAVE_DA_PLOOMES

# Porta do servidor (opcional — default 3000). O Easypanel costuma definir.
PORT=3000
